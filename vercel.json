{
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/api/index.php",
            "dest": "/api/index.php"
        },
        {
            "src": "/assets/(.*).png",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/style.css",
            "dest": "/public/style.css"
        },
        {
            "src": "/datas/data.json",
            "dest": "/public/datas/data.json"
        }
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}